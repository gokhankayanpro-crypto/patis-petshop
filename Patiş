<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Patiş Pet Shop — Barkod Sistemi</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#E08A2C">
<link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/icon-180.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<style>
  :root{
    --cream:#FBF4E8;
    --paper:#FFFFFF;
    --ink:#2B2118;
    --ink-soft:#6E6052;
    --amber:#E08A2C;
    --amber-deep:#B96A1A;
    --teal:#2F6E63;
    --line:#E7D9C2;
    --danger:#C44536;
    --radius:18px;
    --shadow: 0 8px 24px rgba(43,33,24,0.08);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--cream);
    color:var(--ink);
    font-family:'Manrope',sans-serif;
    min-height:100vh;
    -webkit-tap-highlight-color: transparent;
  }
  .bg-pattern{
    position:fixed; inset:0; z-index:0; pointer-events:none; opacity:0.5;
    background-image: radial-gradient(circle at 1px 1px, var(--line) 1.4px, transparent 1.4px);
    background-size: 22px 22px;
  }
  .app{ position:relative; z-index:1; max-width:480px; margin:0 auto; min-height:100vh; display:flex; flex-direction:column; }

  header{
    padding:22px 20px 16px;
    display:flex; align-items:center; justify-content:space-between;
  }
  .brand{ display:flex; align-items:center; gap:10px; }
  .brand-mark{
    width:40px; height:40px; border-radius:12px; background:var(--amber);
    display:flex; align-items:center; justify-content:center; font-size:20px;
    box-shadow: var(--shadow);
    flex-shrink:0;
  }
  .brand h1{
    font-family:'Fraunces', serif; font-weight:700; font-size:21px; margin:0; letter-spacing:-0.02em;
    line-height:1.05;
  }
  .brand span{ display:block; font-family:'Manrope'; font-weight:600; font-size:11px; color:var(--ink-soft); letter-spacing:0.06em; text-transform:uppercase; margin-top:1px;}

  nav.tabs{
    display:flex; gap:6px; padding:0 16px; margin-bottom:14px;
  }
  .tab{
    flex:1; text-align:center; padding:11px 4px; border-radius:14px;
    font-weight:700; font-size:13px; color:var(--ink-soft); cursor:pointer;
    border:1.5px solid transparent; transition: all .15s ease; user-select:none;
  }
  .tab.active{ background:var(--paper); color:var(--amber-deep); border-color:var(--line); box-shadow:var(--shadow); }

  main{ flex:1; padding:0 16px 100px; }
  .view{ display:none; }
  .view.active{ display:block; animation: rise .28s ease; }
  @keyframes rise{ from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;} }

  .card{
    background:var(--paper); border-radius:var(--radius); padding:18px;
    box-shadow:var(--shadow); border:1px solid var(--line); margin-bottom:14px;
  }

  /* --- Scanner --- */
  .scan-stage{
    position:relative; border-radius:var(--radius); overflow:hidden;
    background:#111; aspect-ratio: 1/1; box-shadow:var(--shadow);
    border: 3px solid var(--ink);
  }
  #reader{ width:100%; height:100%; }
  #reader video{ object-fit:cover; width:100%!important; height:100%!important; }
  .scan-frame{
    position:absolute; inset:18%; border-radius:16px;
    border:2.5px solid rgba(255,255,255,0.85);
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.32);
    pointer-events:none;
  }
  .scan-line{
    position:absolute; left:18%; right:18%; top:18%; height:2px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    box-shadow: 0 0 8px var(--amber);
    animation: sweep 1.8s ease-in-out infinite;
    pointer-events:none;
  }
  @keyframes sweep{ 0%{top:18%;} 50%{top:78%;} 100%{top:18%;} }
  .scan-hint{
    text-align:center; color:var(--ink-soft); font-size:13px; margin-top:10px; font-weight:600;
  }
  .scan-toggle{
    width:100%; margin-top:12px; padding:15px; border:none; border-radius:14px;
    background:var(--ink); color:var(--cream); font-weight:700; font-size:15px;
    cursor:pointer; font-family:'Manrope';
  }
  .scan-toggle.stop{ background:var(--danger); }
  .manual-row{ display:flex; gap:8px; margin-top:12px; }
  .manual-row input{
    flex:1; padding:13px 14px; border-radius:12px; border:1.5px solid var(--line);
    font-size:15px; font-family:'Manrope'; background:var(--cream);
  }
  .manual-row button{
    padding:13px 16px; border-radius:12px; border:none; background:var(--teal);
    color:white; font-weight:700; cursor:pointer; font-size:14px;
  }

  /* --- Result card --- */
  .result-card{ display:none; }
  .result-card.show{ display:block; animation: pop .25s cubic-bezier(.2,1.4,.4,1); }
  @keyframes pop{ from{opacity:0; transform:scale(.94);} to{opacity:1; transform:none;} }
  .result-top{ display:flex; justify-content:space-between; align-items:flex-start; gap:10px; }
  .result-name{ font-family:'Fraunces',serif; font-weight:700; font-size:19px; line-height:1.2; }
  .result-barcode{ font-size:12px; color:var(--ink-soft); margin-top:3px; font-weight:600; }
  .paw{ font-size:22px; flex-shrink:0; }
  .result-stats{ display:flex; gap:10px; margin:14px 0; }
  .stat-box{ flex:1; background:var(--cream); border-radius:12px; padding:10px 12px; text-align:center; }
  .stat-box .num{ font-family:'Fraunces',serif; font-weight:700; font-size:20px; color:var(--amber-deep); }
  .stat-box.low .num{ color:var(--danger); }
  .stat-box .lbl{ font-size:11px; color:var(--ink-soft); font-weight:700; text-transform:uppercase; letter-spacing:0.04em; margin-top:2px;}
  .qty-row{ display:flex; align-items:center; gap:12px; margin:14px 0; justify-content:center; }
  .qty-btn{
    width:44px; height:44px; border-radius:50%; border:1.5px solid var(--line); background:var(--cream);
    font-size:20px; font-weight:700; color:var(--ink); cursor:pointer;
  }
  .qty-val{ font-family:'Fraunces',serif; font-size:24px; font-weight:700; min-width:36px; text-align:center; }
  .sell-btn{
    width:100%; padding:16px; border:none; border-radius:14px; background:var(--amber);
    color:white; font-weight:800; font-size:16px; cursor:pointer; font-family:'Manrope';
    box-shadow: var(--shadow);
  }
  .sell-btn:active{ transform: scale(.98); }
  .not-found{ display:none; text-align:center; padding:10px 4px; }
  .not-found.show{ display:block; }
  .not-found .emoji{ font-size:34px; }
  .not-found p{ color:var(--ink-soft); font-weight:600; font-size:14px; margin:6px 0 14px; }
  .not-found button{
    padding:12px 20px; border-radius:12px; border:none; background:var(--ink); color:var(--cream);
    font-weight:700; cursor:pointer;
  }

  /* --- Toast --- */
  .toast{
    position:fixed; bottom:90px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--ink); color:var(--cream); padding:13px 22px; border-radius:50px;
    font-weight:700; font-size:14px; box-shadow:0 10px 30px rgba(0,0,0,0.25);
    opacity:0; transition: all .25s ease; z-index:50; white-space:nowrap;
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  /* --- Products list --- */
  .search-bar{ margin-bottom:12px; }
  .search-bar input{
    width:100%; padding:13px 16px; border-radius:14px; border:1.5px solid var(--line);
    font-size:14px; font-family:'Manrope'; background:var(--paper);
  }
  .prod-row{
    display:flex; align-items:center; gap:12px; padding:13px 0; border-bottom:1px solid var(--line);
  }
  .prod-row:last-child{ border-bottom:none; }
  .prod-info{ flex:1; min-width:0; }
  .prod-info .pname{ font-weight:700; font-size:14.5px; }
  .prod-info .pmeta{ font-size:12px; color:var(--ink-soft); margin-top:2px; }
  .prod-stock{ text-align:right; flex-shrink:0; }
  .prod-stock .n{ font-family:'Fraunces',serif; font-weight:700; font-size:17px; }
  .prod-stock .n.low{ color:var(--danger); }
  .prod-stock .u{ font-size:10.5px; color:var(--ink-soft); font-weight:700; text-transform:uppercase;}
  .prod-edit{
    width:34px; height:34px; border-radius:9px; border:1px solid var(--line); background:var(--cream);
    flex-shrink:0; cursor:pointer; font-size:14px;
  }
  .add-btn{
    position:fixed; bottom:84px; right:max(20px, calc(50% - 240px + 20px)); z-index:30;
    width:56px; height:56px; border-radius:50%; background:var(--amber);
    color:white; font-size:26px; border:none; box-shadow:0 10px 24px rgba(224,138,44,0.45);
    cursor:pointer; display:flex; align-items:center; justify-content:center;
  }

  /* --- Modal --- */
  .modal-overlay{
    position:fixed; inset:0; background:rgba(43,33,24,0.5); z-index:100;
    display:none; align-items:flex-end; justify-content:center;
  }
  .modal-overlay.show{ display:flex; animation: fadein .2s ease; }
  @keyframes fadein{ from{opacity:0;} to{opacity:1;} }
  .modal{
    background:var(--paper); width:100%; max-width:480px; border-radius:24px 24px 0 0;
    padding:24px 20px 28px; animation: slideup .25s cubic-bezier(.2,1,.3,1);
    max-height:88vh; overflow-y:auto;
  }
  @keyframes slideup{ from{transform:translateY(40px);} to{transform:none;} }
  .modal h2{ font-family:'Fraunces',serif; font-size:20px; margin:0 0 16px; }
  .field{ margin-bottom:13px; }
  .field label{ display:block; font-size:12.5px; font-weight:700; color:var(--ink-soft); margin-bottom:5px; text-transform:uppercase; letter-spacing:0.03em;}
  .field input{
    width:100%; padding:12px 14px; border-radius:12px; border:1.5px solid var(--line);
    font-size:15px; font-family:'Manrope'; background:var(--cream);
  }
  .field-row{ display:flex; gap:10px; }
  .field-row .field{ flex:1; }
  .scan-into-field{ display:flex; gap:8px; }
  .scan-into-field input{ flex:1; }
  .scan-into-field button{
    padding:0 14px; border-radius:12px; border:none; background:var(--teal); color:white; font-size:16px; cursor:pointer;
  }
  .modal-actions{ display:flex; gap:10px; margin-top:18px; }
  .modal-actions button{
    flex:1; padding:14px; border-radius:12px; border:none; font-weight:700; cursor:pointer; font-size:14.5px;
  }
  .btn-save{ background:var(--amber); color:white; }
  .btn-delete{ background:var(--cream); color:var(--danger); border:1.5px solid var(--line) !important; }
  .btn-cancel{ background:var(--cream); color:var(--ink); border:1.5px solid var(--line) !important; }

  /* --- Reports --- */
  .report-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:14px; }
  .report-box{ background:var(--paper); border-radius:16px; padding:16px; border:1px solid var(--line); box-shadow:var(--shadow); }
  .report-box .n{ font-family:'Fraunces',serif; font-weight:700; font-size:24px; color:var(--amber-deep); }
  .report-box.profit .n{ color:var(--teal); }
  .report-box .l{ font-size:11.5px; color:var(--ink-soft); font-weight:700; text-transform:uppercase; margin-top:3px;}
  .section-title{ font-family:'Fraunces',serif; font-weight:700; font-size:15px; margin:18px 0 10px; display:flex; align-items:center; gap:8px;}
  .sale-row{ display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid var(--line); font-size:13.5px; }
  .sale-row:last-child{ border-bottom:none; }
  .sale-row .sname{ font-weight:700; }
  .sale-row .stime{ color:var(--ink-soft); font-size:11.5px; margin-top:2px; }
  .sale-row .sright{ text-align:right; }
  .sale-row .samount{ font-weight:700; color:var(--teal); }
  .empty-state{ text-align:center; padding:30px 10px; color:var(--ink-soft); }
  .empty-state .emoji{ font-size:32px; display:block; margin-bottom:8px; }
  .history-note{
    font-size:12.5px; color:var(--ink-soft); margin:0 0 10px; line-height:1.5; font-weight:500;
  }
  .day-clear{
    width:100%; padding:13px; border-radius:12px; border:1.5px solid var(--line); background:var(--paper);
    color:var(--ink-soft); font-weight:700; font-size:13px; cursor:pointer; margin-top:10px;
  }
  .history-day{
    border-bottom:1px solid var(--line); padding:13px 0;
  }
  .history-day:last-child{ border-bottom:none; }
  .history-day-head{
    display:flex; justify-content:space-between; align-items:center; cursor:pointer;
  }
  .history-day-head .hd-date{ font-weight:800; font-size:14px; }
  .history-day-head .hd-sub{ font-size:11.5px; color:var(--ink-soft); font-weight:600; margin-top:2px;}
  .history-day-head .hd-right{ text-align:right; display:flex; align-items:center; gap:8px; }
  .history-day-head .hd-amount{ font-weight:800; color:var(--teal); font-size:14.5px; }
  .history-day-head .hd-chevron{ font-size:12px; color:var(--ink-soft); transition: transform .2s ease; }
  .history-day.open .hd-chevron{ transform:rotate(90deg); }
  .history-day-body{ display:none; padding-top:10px; }
  .history-day.open .history-day-body{ display:block; }
  .history-item{ display:flex; align-items:center; justify-content:space-between; padding:8px 0; font-size:13px; border-top:1px dashed var(--line); gap:8px; }
  .history-item:first-child{ border-top:none; }
  .history-item .hi-name{ font-weight:600; }
  .history-item .hi-time{ font-size:11px; color:var(--ink-soft); margin-top:1px; }
  .history-item .hi-right{ text-align:right; flex-shrink:0; padding-left:6px; }
  .history-item .hi-amount{ font-weight:700; }
  .hi-delete{
    flex-shrink:0; width:30px; height:30px; border-radius:9px; border:1px solid var(--line);
    background:var(--cream); font-size:13px; cursor:pointer; color:var(--danger);
  }

  .bottombar{
    position:fixed; bottom:0; left:0; right:0; z-index:20;
    background:var(--paper); border-top:1px solid var(--line);
  }
  .bottombar-inner{ max-width:480px; margin:0 auto; }
</style>
</head>
<body>
<div class="bg-pattern"></div>
<div class="app">

  <header>
    <div class="brand">
      <div class="brand-mark">🐾</div>
      <div>
        <h1>Patiş</h1>
        <span>Barkod &amp; Stok Sistemi</span>
      </div>
    </div>
  </header>

  <nav class="tabs">
    <div class="tab active" data-view="scan">Satış</div>
    <div class="tab" data-view="products">Ürünler</div>
    <div class="tab" data-view="reports">Rapor</div>
  </nav>

  <main>

    <!-- SCAN VIEW -->
    <section class="view active" id="view-scan">
      <div class="scan-stage">
        <div id="reader"></div>
        <div class="scan-frame"></div>
        <div class="scan-line"></div>
      </div>
      <p class="scan-hint" id="scanHint">Barkodu kare içine getir, otomatik okunacak</p>
      <button class="scan-toggle" id="scanToggleBtn">Taramayı Başlat</button>

      <div class="manual-row">
        <input type="text" id="manualBarcode" placeholder="Barkod okunmazsa elle yaz" inputmode="numeric">
        <button id="manualBtn">Bul</button>
      </div>

      <div class="card result-card" id="resultCard">
        <div class="not-found" id="notFound">
          <div class="emoji">🔍</div>
          <p>Bu barkod kayıtlı değil</p>
          <button id="goAddFromScan">Ürünü Ekle</button>
        </div>
        <div id="foundBlock">
          <div class="result-top">
            <div>
              <div class="result-name" id="rName">—</div>
              <div class="result-barcode" id="rBarcode">—</div>
            </div>
            <div class="paw">🐶</div>
          </div>
          <div class="result-stats">
            <div class="stat-box">
              <div class="num" id="rPrice">—</div>
              <div class="lbl">Satış</div>
            </div>
            <div class="stat-box" id="rStockBox">
              <div class="num" id="rStock">—</div>
              <div class="lbl">Stok</div>
            </div>
          </div>
          <div class="qty-row">
            <button class="qty-btn" id="qtyMinus">−</button>
            <div class="qty-val" id="qtyVal">1</div>
            <button class="qty-btn" id="qtyPlus">+</button>
          </div>
          <button class="sell-btn" id="sellBtn">Satışı Tamamla</button>
        </div>
      </div>
    </section>

    <!-- PRODUCTS VIEW -->
    <section class="view" id="view-products">
      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Ürün adı veya barkod ara...">
      </div>
      <div class="card" id="productListCard">
        <!-- rows injected -->
      </div>
    </section>

    <!-- REPORTS VIEW -->
    <section class="view" id="view-reports">
      <div class="report-grid">
        <div class="report-box">
          <div class="n" id="repToday">0</div>
          <div class="l">Bugün satış adedi</div>
        </div>
        <div class="report-box">
          <div class="n" id="repTodayRevenue">₺0</div>
          <div class="l">Bugün ciro</div>
        </div>
        <div class="report-box profit">
          <div class="n" id="repTodayProfit">₺0</div>
          <div class="l">Bugün kâr</div>
        </div>
        <div class="report-box">
          <div class="n" id="repLowCount">0</div>
          <div class="l">Kritik stok</div>
        </div>
      </div>

      <div class="section-title">⚠️ Kritik Stok</div>
      <div class="card" id="lowStockCard"></div>

      <div class="section-title">🧾 Bugünkü Satışlar</div>
      <div class="card" id="todaySalesCard"></div>
      <button class="day-clear" id="clearTodayBtn">Bugünkü satış listesini gizle</button>

      <div class="section-title">📚 Tüm Zamanlar Geçmişi</div>
      <p class="history-note">Bu kayıtlar silinemez. Sistemi kullanmaya başladığın ilk günden beri tüm satışlar gün gün burada saklanır.</p>
      <div class="card" id="historyCard"></div>
    </section>

  </main>

  <div class="bottombar">
    <div class="bottombar-inner">
      <!-- spacer for fixed add button alignment, content inside main -->
    </div>
  </div>

  <button class="add-btn" id="addBtn" title="Yeni ürün ekle">+</button>
</div>

<!-- MODAL: Add/Edit product -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <h2 id="modalTitle">Yeni Ürün Ekle</h2>
    <div class="field">
      <label>Barkod</label>
      <div class="scan-into-field">
        <input type="text" id="fBarcode" inputmode="numeric" placeholder="Barkod numarası">
        <button id="scanIntoFieldBtn">📷</button>
      </div>
    </div>
    <div class="field">
      <label>Ürün Adı</label>
      <input type="text" id="fName" placeholder="örn. Royal Canin Kitten 2kg">
    </div>
    <div class="field-row">
      <div class="field">
        <label>Alış Fiyatı (₺)</label>
        <input type="number" id="fCost" inputmode="decimal" placeholder="0">
      </div>
      <div class="field">
        <label>Satış Fiyatı (₺)</label>
        <input type="number" id="fPrice" inputmode="decimal" placeholder="0">
      </div>
    </div>
    <div class="field-row">
      <div class="field">
        <label>Stok Adedi</label>
        <input type="number" id="fStock" inputmode="numeric" placeholder="0">
      </div>
      <div class="field">
        <label>Kritik Stok Eşiği</label>
        <input type="number" id="fThreshold" inputmode="numeric" placeholder="3" value="3">
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="cancelModalBtn">Vazgeç</button>
      <button class="btn-delete" id="deleteProductBtn" style="display:none;">Sil</button>
      <button class="btn-save" id="saveProductBtn">Kaydet</button>
    </div>
  </div>
</div>

<!-- MODAL: barcode scan target for the form field -->
<div class="modal-overlay" id="scanModalOverlay">
  <div class="modal">
    <h2>Barkodu Okut</h2>
    <div class="scan-stage" style="aspect-ratio:1/1;">
      <div id="readerModal"></div>
      <div class="scan-frame"></div>
      <div class="scan-line"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="closeScanModalBtn" style="flex:1;">Kapat</button>
    </div>
  </div>
</div>

<!-- MODAL: confirm action -->
<div class="modal-overlay" id="confirmModalOverlay">
  <div class="modal">
    <h2 id="confirmModalTitle">Emin misin?</h2>
    <p id="confirmModalText" style="color:var(--ink-soft); font-size:14px; line-height:1.5; margin:0 0 18px;"></p>
    <div class="modal-actions">
      <button class="btn-cancel" id="confirmModalCancel">Vazgeç</button>
      <button class="btn-delete" id="confirmModalOk">Onayla</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
(function(){
  "use strict";

  // ---------- Storage ----------
  const DB_KEY = 'patis_products_v1';
  const SALES_KEY = 'patis_sales_v1';

  function loadProducts(){
    try{ return JSON.parse(localStorage.getItem(DB_KEY)) || []; }catch(e){ return []; }
  }
  function saveProducts(list){ localStorage.setItem(DB_KEY, JSON.stringify(list)); }
  function loadSales(){
    try{ return JSON.parse(localStorage.getItem(SALES_KEY)) || []; }catch(e){ return []; }
  }
  function saveSales(list){ localStorage.setItem(SALES_KEY, JSON.stringify(list)); }

  let products = loadProducts();
  let sales = loadSales();

  function fmt(n){ return "₺" + Number(n).toLocaleString('tr-TR', {maximumFractionDigits:0}); }
  function findByBarcode(code){ return products.find(p => p.barcode === code); }
  function todayStr(){ return new Date().toISOString().slice(0,10); }

  // ---------- Custom confirm (more reliable than browser confirm() on mobile) ----------
  function confirmAction(title, text, onConfirm){
    document.getElementById('confirmModalTitle').textContent = title;
    document.getElementById('confirmModalText').textContent = text;
    const overlay = document.getElementById('confirmModalOverlay');
    overlay.classList.add('show');
    const okBtn = document.getElementById('confirmModalOk');
    const cancelBtn = document.getElementById('confirmModalCancel');
    function cleanup(){
      overlay.classList.remove('show');
      okBtn.removeEventListener('click', onOk);
      cancelBtn.removeEventListener('click', onCancel);
    }
    function onOk(){ cleanup(); onConfirm(); }
    function onCancel(){ cleanup(); }
    okBtn.addEventListener('click', onOk);
    cancelBtn.addEventListener('click', onCancel);
  }
  let toastTimer;
  function toast(msg){
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(()=> t.classList.remove('show'), 2000);
  }

  // ---------- Tabs ----------
  const tabs = document.querySelectorAll('.tab');
  const views = document.querySelectorAll('.view');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t=>t.classList.remove('active'));
      tab.classList.add('active');
      views.forEach(v=>v.classList.remove('active'));
      document.getElementById('view-' + tab.dataset.view).classList.add('active');
      if(tab.dataset.view === 'products') renderProducts();
      if(tab.dataset.view === 'reports') renderReports();
      if(tab.dataset.view !== 'scan' && scannerRunning) stopScanner();
    });
  });

  // ---------- Scanner (main) ----------
  let html5QrCode = null;
  let scannerRunning = false;
  let lastScanTime = 0;
  let lastScanCode = '';

  function onScanSuccess(decodedText){
    const now = Date.now();
    if(decodedText === lastScanCode && now - lastScanTime < 2500) return; // debounce duplicate
    lastScanCode = decodedText;
    lastScanTime = now;
    handleBarcode(decodedText);
    if(navigator.vibrate) navigator.vibrate(60);
  }

  function isCameraEligible(){
    // Camera APIs require a secure context: https://, or localhost. file:// and plain http:// are blocked by browsers.
    if(window.isSecureContext) return true;
    return false;
  }

  function startScanner(){
    if(!isCameraEligible()){
      showCameraBlockedNotice();
      return;
    }
    if(!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia){
      toast("Bu tarayıcı kamera erişimini desteklemiyor");
      return;
    }
    html5QrCode = new Html5Qrcode("reader");
    const config = { fps: 10, qrbox: { width: 230, height: 230 } };
    html5QrCode.start({ facingMode: "environment" }, config, onScanSuccess)
      .then(()=>{
        scannerRunning = true;
        const btn = document.getElementById('scanToggleBtn');
        btn.textContent = "Taramayı Durdur";
        btn.classList.add('stop');
      })
      .catch(err=>{
        const name = (err && err.name) || '';
        if(name === 'NotAllowedError'){
          toast("Kamera izni reddedildi, tarayıcı ayarlarından izin ver");
        } else if(name === 'NotFoundError'){
          toast("Bu cihazda kamera bulunamadı");
        } else if(name === 'NotReadableError'){
          toast("Kamera başka bir uygulama tarafından kullanılıyor");
        } else {
          toast("Kamera açılamadı: " + (name || 'bilinmeyen hata'));
        }
        console.error(err);
      });
  }

  function showCameraBlockedNotice(){
    const reader = document.getElementById('reader');
    reader.innerHTML = `
      <div style="display:flex; align-items:center; justify-content:center; height:100%; padding:20px; text-align:center;">
        <div style="color:#fff;">
          <div style="font-size:32px; margin-bottom:10px;">🔒</div>
          <div style="font-weight:700; font-size:14px; margin-bottom:6px;">Kamera bu bağlantıda çalışmıyor</div>
          <div style="font-size:12.5px; opacity:0.85; line-height:1.5;">
            Tarayıcılar, güvenlik nedeniyle kamerayı sadece <strong>https://</strong> ile başlayan adreslerde çalıştırır.<br><br>
            Bu dosyayı doğrudan açtığında (file:// veya indirilenler) kamera engellenir.<br><br>
            Aşağıdan barkodu elle yazarak satışa devam edebilirsin.
          </div>
        </div>
      </div>`;
  }
  function stopScanner(){
    if(html5QrCode && scannerRunning){
      html5QrCode.stop().then(()=>{
        html5QrCode.clear();
        scannerRunning = false;
        const btn = document.getElementById('scanToggleBtn');
        btn.textContent = "Taramayı Başlat";
        btn.classList.remove('stop');
      }).catch(()=>{});
    }
  }
  document.getElementById('scanToggleBtn').addEventListener('click', ()=>{
    scannerRunning ? stopScanner() : startScanner();
  });

  // ---------- Manual barcode entry ----------
  document.getElementById('manualBtn').addEventListener('click', ()=>{
    const v = document.getElementById('manualBarcode').value.trim();
    if(v) handleBarcode(v);
  });
  document.getElementById('manualBarcode').addEventListener('keydown', (e)=>{
    if(e.key === 'Enter'){
      const v = e.target.value.trim();
      if(v) handleBarcode(v);
    }
  });

  // ---------- Result handling ----------
  let currentProduct = null;
  let currentQty = 1;

  function handleBarcode(code){
    const p = findByBarcode(code);
    const card = document.getElementById('resultCard');
    card.classList.add('show');
    if(!p){
      currentProduct = null;
      document.getElementById('notFound').classList.add('show');
      document.getElementById('foundBlock').style.display = 'none';
      document.getElementById('notFound').dataset.pendingBarcode = code;
      return;
    }
    currentProduct = p;
    currentQty = 1;
    document.getElementById('notFound').classList.remove('show');
    document.getElementById('foundBlock').style.display = 'block';
    document.getElementById('rName').textContent = p.name;
    document.getElementById('rBarcode').textContent = p.barcode;
    document.getElementById('rPrice').textContent = fmt(p.price);
    document.getElementById('rStock').textContent = p.stock;
    document.getElementById('qtyVal').textContent = currentQty;
    const stockBox = document.getElementById('rStockBox');
    stockBox.classList.toggle('low', p.stock <= p.threshold);
  }

  document.getElementById('goAddFromScan').addEventListener('click', ()=>{
    const code = document.getElementById('notFound').dataset.pendingBarcode || '';
    openProductModal(null, code);
  });

  document.getElementById('qtyMinus').addEventListener('click', ()=>{
    if(currentQty > 1){ currentQty--; document.getElementById('qtyVal').textContent = currentQty; }
  });
  document.getElementById('qtyPlus').addEventListener('click', ()=>{
    if(currentProduct && currentQty < currentProduct.stock){ currentQty++; document.getElementById('qtyVal').textContent = currentQty; }
    else if(currentProduct) toast("Stokta yeterli ürün yok");
  });

  document.getElementById('sellBtn').addEventListener('click', ()=>{
    if(!currentProduct) return;
    if(currentProduct.stock < currentQty){ toast("Stok yetersiz"); return; }
    currentProduct.stock -= currentQty;
    saveProducts(products);
    sales.push({
      id: 'sale_' + Date.now() + '_' + Math.random().toString(36).slice(2,8),
      barcode: currentProduct.barcode,
      name: currentProduct.name,
      qty: currentQty,
      price: currentProduct.price,
      cost: currentProduct.cost,
      total: currentProduct.price * currentQty,
      profit: (currentProduct.price - currentProduct.cost) * currentQty,
      date: todayStr(),
      time: new Date().toLocaleTimeString('tr-TR', {hour:'2-digit', minute:'2-digit'}),
      ts: Date.now()
    });
    saveSales(sales);
    toast(`✅ Satıldı: ${currentProduct.name} × ${currentQty}`);
    document.getElementById('resultCard').classList.remove('show');
    document.getElementById('manualBarcode').value = '';
    currentProduct = null;
  });

  // ---------- Product list ----------
  function renderProducts(filter){
    const list = document.getElementById('productListCard');
    const term = (filter || '').toLowerCase().trim();
    const filtered = products.filter(p =>
      !term || p.name.toLowerCase().includes(term) || p.barcode.includes(term)
    ).sort((a,b)=> a.name.localeCompare(b.name, 'tr'));

    if(filtered.length === 0){
      list.innerHTML = products.length === 0
        ? `<div class="empty-state"><span class="emoji">🐾</span>Henüz ürün eklemedin<br><span style="font-size:12px;">Sağ alttaki + butonuyla ilk ürününü ekle</span></div>`
        : `<div class="empty-state"><span class="emoji">📦</span>Ürün bulunamadı</div>`;
      return;
    }
    list.innerHTML = filtered.map(p => `
      <div class="prod-row">
        <div class="prod-info">
          <div class="pname">${escapeHtml(p.name)}</div>
          <div class="pmeta">${escapeHtml(p.barcode)} · ${fmt(p.price)}</div>
        </div>
        <div class="prod-stock">
          <div class="n ${p.stock <= p.threshold ? 'low' : ''}">${p.stock}</div>
          <div class="u">adet</div>
        </div>
        <button class="prod-edit" data-barcode="${escapeAttr(p.barcode)}">✎</button>
      </div>
    `).join('');

    list.querySelectorAll('.prod-edit').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const prod = findByBarcode(btn.dataset.barcode);
        openProductModal(prod);
      });
    });
  }
  function escapeHtml(s){ return String(s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
  function escapeAttr(s){ return escapeHtml(s); }

  document.getElementById('searchInput').addEventListener('input', (e)=>{
    renderProducts(e.target.value);
  });

  // ---------- Add/Edit modal ----------
  let editingBarcode = null;
  function openProductModal(product, prefillBarcode){
    editingBarcode = product ? product.barcode : null;
    document.getElementById('modalTitle').textContent = product ? "Ürünü Düzenle" : "Yeni Ürün Ekle";
    document.getElementById('fBarcode').value = product ? product.barcode : (prefillBarcode || '');
    document.getElementById('fName').value = product ? product.name : '';
    document.getElementById('fCost').value = product ? product.cost : '';
    document.getElementById('fPrice').value = product ? product.price : '';
    document.getElementById('fStock').value = product ? product.stock : '';
    document.getElementById('fThreshold').value = product ? product.threshold : 3;
    document.getElementById('deleteProductBtn').style.display = product ? 'block' : 'none';
    document.getElementById('modalOverlay').classList.add('show');
  }
  function closeProductModal(){
    document.getElementById('modalOverlay').classList.remove('show');
    editingBarcode = null;
  }
  document.getElementById('addBtn').addEventListener('click', ()=> openProductModal(null));
  document.getElementById('cancelModalBtn').addEventListener('click', closeProductModal);

  document.getElementById('saveProductBtn').addEventListener('click', ()=>{
    const barcode = document.getElementById('fBarcode').value.trim();
    const name = document.getElementById('fName').value.trim();
    const cost = parseFloat(document.getElementById('fCost').value) || 0;
    const price = parseFloat(document.getElementById('fPrice').value) || 0;
    const stock = parseInt(document.getElementById('fStock').value) || 0;
    const threshold = parseInt(document.getElementById('fThreshold').value) || 3;

    if(!barcode || !name){ toast("Barkod ve ürün adı gerekli"); return; }

    const existingOther = products.find(p => p.barcode === barcode && p.barcode !== editingBarcode);
    if(existingOther){ toast("Bu barkod başka bir üründe kayıtlı"); return; }

    if(editingBarcode){
      const p = findByBarcode(editingBarcode);
      p.barcode = barcode; p.name = name; p.cost = cost; p.price = price; p.stock = stock; p.threshold = threshold;
    } else {
      products.push({barcode, name, cost, price, stock, threshold});
    }
    saveProducts(products);
    toast("Kaydedildi");
    closeProductModal();
    renderProducts(document.getElementById('searchInput').value);
  });

  document.getElementById('deleteProductBtn').addEventListener('click', ()=>{
    if(!editingBarcode) return;
    const barcodeToDelete = editingBarcode;
    confirmAction(
      "Ürünü sil?",
      "Bu ürün listeden kaldırılacak. Bu işlem geri alınamaz.",
      ()=>{
        products = products.filter(p => p.barcode !== barcodeToDelete);
        saveProducts(products);
        toast("Ürün silindi");
        closeProductModal();
        renderProducts(document.getElementById('searchInput').value);
      }
    );
  });

  // ---------- Scan-into-field (for add product form) ----------
  let html5QrCodeModal = null;
  let modalScanRunning = false;
  document.getElementById('scanIntoFieldBtn').addEventListener('click', ()=>{
    if(!isCameraEligible()){
      toast("Kamera sadece https:// adresinde çalışır, barkodu elle yaz");
      return;
    }
    document.getElementById('scanModalOverlay').classList.add('show');
    html5QrCodeModal = new Html5Qrcode("readerModal");
    html5QrCodeModal.start({ facingMode: "environment" }, { fps:10, qrbox:{width:220,height:220} }, (decoded)=>{
      document.getElementById('fBarcode').value = decoded;
      closeScanModal();
      if(navigator.vibrate) navigator.vibrate(60);
    }).then(()=>{ modalScanRunning = true; }).catch((err)=>{
      toast("Kamera açılamadı");
      console.error(err);
    });
  });
  function closeScanModal(){
    document.getElementById('scanModalOverlay').classList.remove('show');
    if(html5QrCodeModal && modalScanRunning){
      html5QrCodeModal.stop().then(()=>html5QrCodeModal.clear()).catch(()=>{});
      modalScanRunning = false;
    }
  }
  document.getElementById('closeScanModalBtn').addEventListener('click', closeScanModal);

  // ---------- Reports ----------
  function renderReports(){
    const today = todayStr();
    const cutoff = hiddenCutoffs[today] || 0;
    // visibleTodaySales = today's sales recorded AFTER the hide action (or all, if never hidden)
    const visibleTodaySales = sales.filter(s => s.date === today && (s.ts || 0) > cutoff);
    const totalQty = visibleTodaySales.reduce((a,s)=>a+s.qty,0);
    const totalRevenue = visibleTodaySales.reduce((a,s)=>a+s.total,0);
    const totalProfit = visibleTodaySales.reduce((a,s)=>a+s.profit,0);
    const lowStock = products.filter(p => p.stock <= p.threshold);

    document.getElementById('repToday').textContent = totalQty;
    document.getElementById('repTodayRevenue').textContent = fmt(totalRevenue);
    document.getElementById('repTodayProfit').textContent = fmt(totalProfit);
    document.getElementById('repLowCount').textContent = lowStock.length;

    const lowCard = document.getElementById('lowStockCard');
    lowCard.innerHTML = lowStock.length === 0
      ? `<div class="empty-state"><span class="emoji">✅</span>Kritik stokta ürün yok</div>`
      : lowStock.map(p => `
        <div class="prod-row">
          <div class="prod-info"><div class="pname">${escapeHtml(p.name)}</div><div class="pmeta">${escapeHtml(p.barcode)}</div></div>
          <div class="prod-stock"><div class="n low">${p.stock}</div><div class="u">adet</div></div>
        </div>
      `).join('');

    const salesCard = document.getElementById('todaySalesCard');
    const clearBtn = document.getElementById('clearTodayBtn');

    if(visibleTodaySales.length === 0 && cutoff > 0){
      salesCard.innerHTML = `<div class="empty-state"><span class="emoji">🙈</span>Bugünkü liste gizlendi<br><span style="font-size:12px;">(Geçmiş kaydı duruyor, alttaki Tüm Zamanlar bölümünden görebilirsin)</span></div>`;
      clearBtn.textContent = "Bugünkü listeyi tekrar göster";
    } else {
      const reversedSales = [...visibleTodaySales].reverse();
      salesCard.innerHTML = reversedSales.length === 0
        ? `<div class="empty-state"><span class="emoji">🧾</span>Bugün henüz satış yok</div>`
        : reversedSales.map(s => `
          <div class="sale-row">
            <div><div class="sname">${escapeHtml(s.name)} × ${s.qty}</div><div class="stime">${s.time}</div></div>
            <div class="sright"><div class="samount">${fmt(s.total)}</div></div>
          </div>
        `).join('');
      clearBtn.textContent = "Bugünkü satış listesini gizle";
    }

    renderHistory();
  }

  const HIDDEN_CUTOFFS_KEY = 'patis_hidden_cutoffs_v1';
  function loadHiddenCutoffs(){
    try{ return JSON.parse(localStorage.getItem(HIDDEN_CUTOFFS_KEY)) || {}; }catch(e){ return {}; }
  }
  function saveHiddenCutoffs(obj){ localStorage.setItem(HIDDEN_CUTOFFS_KEY, JSON.stringify(obj)); }
  let hiddenCutoffs = loadHiddenCutoffs(); // { "2026-06-19": 1750000000000 } -> sales with ts <= cutoff are hidden from today's view/stats

  document.getElementById('clearTodayBtn').addEventListener('click', ()=>{
    const today = todayStr();
    if(hiddenCutoffs[today]){
      delete hiddenCutoffs[today];
      saveHiddenCutoffs(hiddenCutoffs);
      renderReports();
      toast("Bugünkü liste tekrar gösteriliyor");
      return;
    }
    confirmAction(
      "Bugünkü listeyi gizle?",
      "Bu sadece bugünkü satış listesi ile bugünkü adet/ciro/kâr özetini sıfırlar. Satış kayıtların silinmez, Tüm Zamanlar Geçmişi'nde her zaman saklı kalır.",
      ()=>{
        hiddenCutoffs[today] = Date.now();
        saveHiddenCutoffs(hiddenCutoffs);
        renderReports();
        toast("Bugünkü liste gizlendi");
      }
    );
  });
  function dayLabel(dateStr){
    const today = todayStr();
    const d = new Date(dateStr);
    const yest = new Date(); yest.setDate(yest.getDate()-1);
    const yestStr = yest.toISOString().slice(0,10);
    if(dateStr === today) return "Bugün";
    if(dateStr === yestStr) return "Dün";
    return d.toLocaleDateString('tr-TR', { day:'2-digit', month:'long', year:'numeric', weekday:'long' });
  }

  function renderHistory(){
    const card = document.getElementById('historyCard');
    // backfill id for any legacy sales recorded before this feature existed
    let needsSave = false;
    sales.forEach(s => {
      if(!s.id){ s.id = 'sale_' + (s.ts || Date.now()) + '_' + Math.random().toString(36).slice(2,8); needsSave = true; }
    });
    if(needsSave) saveSales(sales);

    if(sales.length === 0){
      card.innerHTML = `<div class="empty-state"><span class="emoji">📚</span>Henüz kayıtlı satış yok</div>`;
      return;
    }
    // group by date, newest first
    const byDate = {};
    sales.forEach(s => { (byDate[s.date] = byDate[s.date] || []).push(s); });
    const dates = Object.keys(byDate).sort((a,b)=> b.localeCompare(a));

    card.innerHTML = dates.map((date, idx) => {
      const items = byDate[date];
      const totalQty = items.reduce((a,s)=>a+s.qty,0);
      const totalAmount = items.reduce((a,s)=>a+s.total,0);
      const itemsHtml = [...items].reverse().map(s => `
        <div class="history-item">
          <div><div class="hi-name">${escapeHtml(s.name)} × ${s.qty}</div><div class="hi-time">${s.time}</div></div>
          <div class="hi-right"><div class="hi-amount">${fmt(s.total)}</div></div>
          <button class="hi-delete" data-id="${escapeAttr(s.id)}" title="Bu kaydı sil">🗑</button>
        </div>
      `).join('');
      return `
        <div class="history-day" data-idx="${idx}">
          <div class="history-day-head">
            <div>
              <div class="hd-date">${dayLabel(date)}</div>
              <div class="hd-sub">${items.length} satış · ${totalQty} ürün</div>
            </div>
            <div class="hd-right">
              <div class="hd-amount">${fmt(totalAmount)}</div>
              <div class="hd-chevron">▶</div>
            </div>
          </div>
          <div class="history-day-body">${itemsHtml}</div>
        </div>
      `;
    }).join('');

    card.querySelectorAll('.hi-delete').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const saleId = btn.dataset.id;
        const sale = sales.find(s => s.id === saleId);
        if(!sale) return;
        confirmAction(
          "Bu satışı sil?",
          `${sale.name} × ${sale.qty} kaydı kalıcı olarak silinecek ve ${sale.qty} adet stoğa geri eklenecek. Bu işlem geri alınamaz.`,
          ()=>{
            sales = sales.filter(s => s.id !== saleId);
            saveSales(sales);
            const prod = findByBarcode(sale.barcode);
            if(prod){
              prod.stock += sale.qty;
              saveProducts(products);
            }
            toast(`Satış silindi, ${sale.qty} adet stoğa eklendi`);
            renderReports();
          }
        );
      });
    });

    card.querySelectorAll('.history-day-head').forEach(head => {
      head.addEventListener('click', ()=>{
        head.closest('.history-day').classList.toggle('open');
      });
    });
  }

  // ---------- Service worker registration (for PWA/offline support) ----------
  if('serviceWorker' in navigator && window.isSecureContext){
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('./sw.js').catch(()=>{});
    });
  }

  // ---------- Init ----------
  renderProducts();
  if(!isCameraEligible()){
    document.getElementById('scanHint').innerHTML = '⚠️ Kamera bu bağlantıda çalışmaz (https:// gerekir) — barkodu elle yaz';
    document.getElementById('scanHint').style.color = 'var(--danger)';
  }
})();
</script>
</body>
</html>
